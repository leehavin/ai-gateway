{
  "version": 1,
  "defaults": {
    "dbgptBaseUrl": "http://42.193.110.76:5670",
    "cozeEndpoint": "api.coze.cn",
    "timeoutSeconds": 120,
    "maxHistoryTurns": 20
  },
  "domains": [
    {
      "id": "patent-coze",
      "displayName": "专利助手（Coze）",
      "chatMode": "CozeAgent",
      "provider": "coze",
      "placeholder": "向 Coze 专利 Bot 提问…",
      "quickPrompts": [
        "今年新申请案件授权率",
        "客户回款情况"
      ],
      "systemPrompt": "你是专利业务管理系统的智能助手。",
      "coze": {
        "botId": "YOUR_COZE_BOT_ID",
        "apiKeyRef": "coze-main",
        "autoSaveHistory": true,
        "userIdPrefix": "patent"
      }
    },
    {
      "id": "legal",
      "displayName": "法务问答（演示）",
      "chatMode": "DbGptApp",
      "provider": "dbgpt",
      "model": "deepseek-ai/DeepSeek-V3",
      "systemPrompt": "你是企业法务助手。",
      "dbgpt": {
        "chatMode": "chat_normal"
      }
    },
    {
      "id": "patent",
      "displayName": "专利智能助手（DB-GPT）",
      "chatMode": "DbGptApp",
      "provider": "dbgpt",
      "model": "deepseek-ai/DeepSeek-V3",
      "placeholder": "@智能体，可对他说今天新登记的官文有多少？",
      "quickPrompts": [
        "今年新申请案件授权率",
        "智能客服",
        "客户回款情况",
        "专利业务知识库",
        "查看今年通过驳回复审，获得授权的案件"
      ],
      "systemPrompt": "你是专利业务管理系统的智能助手。",
      "dbgpt": {
        "chatMode": "chat_normal"
      }
    },
    {
      "id": "data-query",
      "displayName": "数据问数",
      "chatMode": "DbGptData",
      "provider": "dbgpt",
      "model": "deepseek-ai/DeepSeek-V3",
      "quickPrompts": [
        "Walmart_Sales 表有多少行？",
        "按州统计销售总额前5名",
        "2023年各品类销售额对比"
      ],
      "dbgpt": {
        "chatMode": "chat_data",
        "datasourceId": "Walmart_Sales"
      }
    },
    {
      "id": "finance-app",
      "displayName": "财务分析",
      "chatMode": "DbGptApp",
      "provider": "dbgpt",
      "model": "deepseek-ai/DeepSeek-V3",
      "dbgpt": {
        "chatMode": "chat_normal"
      }
    }
  ]
}
