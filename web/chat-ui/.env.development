# 留空使用 Vite 代理 /v1 → Gateway；直连可改为 http://127.0.0.1:5080
VITE_GATEWAY_URL=
# 开启后使用 Gateway /v1/auth/login（sys_user 账号），不再使用 demo-token
VITE_REQUIRE_LOGIN=true
# VITE_DATACHAT_TOKEN=demo-token
VITE_DEFAULT_DOMAIN=
# true 时侧栏/会话从 Gateway SQLite 读写（需 Gateway:EnableSessionApi）
VITE_USE_SERVER_SESSIONS=false
